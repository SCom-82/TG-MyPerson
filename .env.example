# PostgreSQL connection string (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://postgres:YOUR_PASSWORD@localhost:5432/tg_myperson

# Telegram API credentials (from https://my.telegram.org)
TG_API_ID=12345678
TG_API_HASH=your_api_hash_here

# [DEPRECATED] Phone number for first-time Telegram login via legacy singleton path.
# Not used after multi-account refactor (Phase 1-4). Session bootstrap now goes via:
#   POST /api/v1/accounts  →  POST /auth/login?session=<alias>  →  POST /auth/code?session=<alias>
# Kept for backward compatibility — pydantic-settings ignores unknown vars in the env file.
TG_PHONE_NUMBER=+79001234567

# [DEPRECATED] Session string for the legacy tg_session singleton store.
# Not used after multi-account refactor (Phase 1-4). The tg_session table was dropped
# in migration 004. Sessions are now stored in account_sessions (accounts table).
# Kept for backward compatibility with existing deployments that already have this set.
TG_SESSION_STRING=

# API key for REST API authentication (leave empty to disable — for local dev only)
API_KEY=

# Admin API key for /api/v1/accounts/* endpoints (CRUD account management).
# REQUIRED to use admin endpoints. If empty — admin endpoints return 503.
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
TG_ADMIN_API_KEY=

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# User timezone (IANA format)
USER_TIMEZONE=Europe/Samara
