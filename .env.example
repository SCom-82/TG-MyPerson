# PostgreSQL connection string (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://postgres:YOUR_PASSWORD@localhost:5432/tg_myperson

# Telegram API credentials (from https://my.telegram.org)
TG_API_ID=12345678
TG_API_HASH=your_api_hash_here

# Phone number for Telegram login (international format)
TG_PHONE_NUMBER=+79001234567

# Session string (filled after first auth, leave empty on first run)
TG_SESSION_STRING=

# API key for REST API authentication (leave empty to disable — for local dev only)
API_KEY=

# Admin API key for /api/v1/accounts/* endpoints (CRUD account management).
# REQUIRED to use admin endpoints. If empty — admin endpoints return 503.
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
TG_ADMIN_API_KEY=

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# User timezone (IANA format)
USER_TIMEZONE=Europe/Samara
